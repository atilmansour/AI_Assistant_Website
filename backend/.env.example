OPENAI_KEY=Bearer your_openai_key
GEMINI_KEY=your_gemini_key
CLAUDE_KEY=your_claude_key
GROQ_KEY=Bearer your_groq_key

ALLOWED_ORIGIN=http://localhost:3000
# For deployed frontend/API CORS, prefer comma-separated ALLOWED_ORIGINS.
# Example: ALLOWED_ORIGINS=https://main.d2gkp0fur5ysdy.amplifyapp.com,http://localhost:3000
ALLOWED_ORIGINS=
PORT=5050

REACT_APP_BucketS3=your_s3_bucket_name
ADMIN_PASSWORD=change_this_admin_password

# Only keep these if your local backend code needs AWS credentials.
# For deployed AWS Lambda, prefer an IAM execution role instead of static keys.
REACT_APP_ACCESS_KEY_ID=your_aws_access_key_id
REACT_APP_SECRET_ACCESS_KEY=your_aws_secret_access_key
REACT_APP_REGION=your_aws_region
